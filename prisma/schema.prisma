generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTH ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  phone         String?
  avatar        String?
  role          String    @default("ADMIN") // ADMIN, MANAGER, OFFICE, ENGINEER
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  companyUsers  CompanyUser[]
  auditLogs     AuditLog[]
  notifications Notification[]
  jobsAssigned  Job[]      @relation("assignedEngineer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== COMPANY ====================

model Company {
  id                String    @id @default(cuid())
  name              String
  tradingName       String?
  companyNumber     String?
  vatNumber         String?
  address           String?
  postcode          String?
  phone             String?
  email             String?
  website           String?
  gasSafeNumber     String?   // Gas Safe registered company number
  niceicNumber      String?   // NICEIC approved contractor number
  fgasNumber        String?   // F-Gas registered company number
  cisRegistered     Boolean   @default(false)
  utrnumber         String?   // UTR for CIS
  logo              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users            CompanyUser[]
  customers        Customer[]
  jobs             Job[]
  engineers        Engineer[]
  vehicles         Vehicle[]
  certificates     Certificate[]
  invoices         Invoice[]
  quotes           Quote[]
  cisRecords       CisRecord[]
  auditLogs        AuditLog[]
}

model CompanyUser {
  id        String @id @default(cuid())
  userId    String
  companyId String
  role      String @default("OFFICE") // ADMIN, MANAGER, OFFICE

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

// ==================== CUSTOMERS ====================

model Customer {
  id             String    @id @default(cuid())
  companyId      String
  name           String
  company        String?
  email          String?
  phone          String
  mobile         String?
  address        String?
  postcode       String?
  accountNumber  String?   // Customer account reference
  propertyType   String?   // residential, commercial, landlord
  paymentTerms   String?   // cash, 30_days, 60_days
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyOwner Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs         Job[]
  invoices     Invoice[]
  quotes       Quote[]
  properties   Property[]
}

model Property {
  id          String   @id @default(cuid())
  customerId  String
  address     String
  postcode    String
  propertyType String? // house, flat, commercial, landlord_portfolio
  accessNotes  String?
  keyLocation  String?
  createdAt    DateTime @default(now())

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs         Job[]
  certificates Certificate[]
}

// ==================== ENGINEERS ====================

model Engineer {
  id                   String    @id @default(cuid())
  companyId            String
  userId               String?   // Link to User account
  name                 String
  email                String?
  phone                String
  mobile               String?
  employeeNumber       String?
  gasSafeNumber        String?   // Individual Gas Safe registration
  gasSafeExpiry        DateTime?
  niceicCard           String?   // NICEIC card number
  niceicExpiry         DateTime?
  fgasNumber           String?   // F-Gas individual certificate
  fgasExpiry           DateTime?
  cscsCard             String?   // Construction Skills Certification Scheme
  cscsExpiry           DateTime?
  drivingLicence       String?
  dvlaExpiry           DateTime?
  cisTaxStatus         String?   // gross, 20, 30, subcontractor
  cisVerificationRef   String?
  niNumber             String?
  bankAccount          String?
  sortCode             String?
  hourlyRate           Float?
  status               String    @default("active") // active, inactive, holiday, sick
  vehicleId            String?
  photo                String?
  skills               String?   // JSON array of skills: plumbing, heating, electrical, etc.
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  jobs         JobEngineer[]
  certificates Certificate[]
  cisRecords   CisRecord[]
}

// ==================== VEHICLES / FLEET ====================

model Vehicle {
  id             String    @id @default(cuid())
  companyId      String
  registration   String    @unique
  make           String?
  model          String?
  year           Int?
  colour         String?
  fuelType       String?   // diesel, petrol, electric, hybrid
  motExpiry      DateTime?
  taxExpiry      DateTime?
  insuranceExpiry DateTime?
  serviceDate    DateTime?
  serviceDueKm   Int?
  currentKm      Int?
  vehicleType    String?   // van, car, truck
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  engineers Engineer[]
}

// ==================== JOBS ====================

model Job {
  id                String    @id @default(cuid())
  companyId         String
  customerId        String
  propertyId        String?
  jobNumber         String    @unique
  title             String
  description       String?
  jobType           String    // install, repair, service, inspection, emergency
  trade             String    // plumbing, heating, electrical, hvac, multi
  priority          String    @default("normal") // urgent, high, normal, low
  status            String    @default("scheduled") // quote, scheduled, in_progress, completed, invoiced, cancelled
  scheduledDate     DateTime?
  scheduledTime     String?
  completedDate     DateTime?
  assignedEngineerId String?
  estimatedDuration Float?    // hours
  actualDuration    Float?
  calloutCharge     Float?
  labourCost        Float?
  materialsCost     Float?
  totalCost         Float?
  quoteId           String?
  invoiceId         String?
  beforePhotos      String?   // JSON array of URLs
  afterPhotos       String?   // JSON array of URLs
  customerSignature String?   // Data URL
  engineerNotes     String?
  internalNotes     String?
  requiresCertificate Boolean @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property         Property?      @relation(fields: [propertyId], references: [id])
  assignedEngineer User?          @relation("assignedEngineer", fields: [assignedEngineerId], references: [id])
  quote            Quote?         @relation(fields: [quoteId], references: [id])
  invoice          Invoice?       @relation(fields: [invoiceId], references: [id])
  engineers        JobEngineer[]
  materials        JobMaterial[]
  certificates     Certificate[]
  timeline         JobTimeline[]
}

model JobEngineer {
  id         String  @id @default(cuid())
  jobId      String
  engineerId String

  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  engineer Engineer @relation(fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([jobId, engineerId])
}

model JobMaterial {
  id          String  @id @default(cuid())
  jobId       String
  description String
  partNumber  String?
  quantity    Float   @default(1)
  unitPrice   Float
  totalPrice  Float
  supplier    String?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobTimeline {
  id          String   @id @default(cuid())
  jobId       String
  timestamp   DateTime @default(now())
  event       String   // created, scheduled, started, paused, resumed, completed, invoiced, paid
  description String?
  userId      String?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ==================== QUOTES ====================

model Quote {
  id          String    @id @default(cuid())
  companyId   String
  customerId  String
  quoteNumber String    @unique
  title       String
  description String?
  validUntil  DateTime?
  subtotal    Float
  vat         Float
  total       Float
  status      String    @default("draft") // draft, sent, accepted, rejected, expired
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items     QuoteItem[]
  jobs      Job[]
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  totalPrice  Float

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// ==================== INVOICES ====================

model Invoice {
  id            String    @id @default(cuid())
  companyId     String
  customerId    String
  invoiceNumber String    @unique
  title         String?
  date          DateTime  @default(now())
  dueDate       DateTime?
  subtotal      Float
  vat           Float
  total         Float
  cisDeduction  Float?    // CIS deduction amount if applicable
  cisRate       Float?    // 20 or 30
  netPayable    Float?    // Total minus CIS deduction
  status        String    @default("unpaid") // draft, sent, unpaid, partial, paid, overdue
  paidAmount    Float?
  paidDate      DateTime?
  paymentMethod String?   // bank_transfer, card, cash, cheque
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  jobs     Job[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  totalPrice  Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ==================== CERTIFICATES ====================

model Certificate {
  id             String    @id @default(cuid())
  companyId      String
  jobId          String?
  engineerId     String?
  customerId     String?   // Denormalized for quick lookup
  propertyId     String?
  certificateType String   // gas_safe_cp12, niceic_eicr, niceic_minor_works, fgas_install, fgas_service, epc
  certificateNumber String @unique
  issueDate      DateTime  @default(now())
  expiryDate     DateTime?
  nextServiceDue DateTime?
  status         String    @default("valid") // valid, expired, recalled
  pdfUrl         String?
  details        String?   // JSON with certificate-specific data
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job      Job?      @relation(fields: [jobId], references: [id])
  engineer Engineer? @relation(fields: [engineerId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
}

// ==================== CIS TAX ====================

model CisRecord {
  id              String   @id @default(cuid())
  companyId       String
  engineerId      String?  // If paying subcontractor
  monthYear       String   // "2026-03" format
  grossPayment    Float
  cisRate         Float    // 0 (gross), 20, or 30
  cisDeduction    Float
  netPayment      Float
  paymentDate     DateTime?
  hmrcSubmitted   Boolean  @default(false)
  hmrcSubmittedDate DateTime?
  hmrcReference   String?
  notes           String?
  createdAt       DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  engineer Engineer? @relation(fields: [engineerId], references: [id])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // info, warning, deadline, system
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  companyId String?
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])
}

// ==================== CONTACT FORM ====================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  source    String?  // utm_source
  medium    String?  // utm_medium
  campaign  String?  // utm_campaign
  device    String?
  createdAt DateTime @default(now())
}
